rules_version = '2';
// Force re-deploy v2
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: verifica si el usuario tiene rol 'admin' en /usuarios/{uid} ──
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role in ["admin", "superadmin"];
    }

    // Subadmin: rol restringido a cold outreach (prospectos / seguimientos / mensajería).
    function isSubadmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == "subadmin";
    }

    function isOwner(ownerId) {
      return request.auth != null && request.auth.uid == ownerId;
    }

    // ── leads (formulario público) ──────────────────────────────────────────
    // Crear: público, pero validate required fields + size limits to prevent spam
    // Leer, actualizar, eliminar: solo admin
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(["contactName", "businessName", "phone", "email", "status"])
        && request.resource.data.contactName is string
        && request.resource.data.contactName.size() > 0
        && request.resource.data.contactName.size() < 200
        && request.resource.data.businessName is string
        && request.resource.data.businessName.size() > 0
        && request.resource.data.businessName.size() < 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 7
        && request.resource.data.phone.size() < 20
        && request.resource.data.email is string
        && request.resource.data.email.size() > 5
        && request.resource.data.status == "nuevo";
      allow read, update, delete: if isAdmin();
    }

    // ── prospectos_frios (CRM / Scraper) ────────────────────────────────────
    // TODAS las operaciones: solo admin
    match /prospectos_frios/{docId} {
      allow read, write: if isAdmin() || isSubadmin();
    }

    // ── funeraria_leads (scraper_funerarias.py → Historias Infinitas) ──────
    // Mismo patrón que prospectos_frios: solo admin.
    // Lo escribe el scraper autenticado como usuario admin vía REST API, y
    // lo lee /admin/prospectos (pestaña Funerarias).
    match /funeraria_leads/{docId} {
      allow read, write: if isAdmin() || isSubadmin();
    }

    // ── outreach_queue (cola manual de seguimientos USA) ────────────────────
    // La escribe el cron outreach-followups vía Admin SDK; el panel
    // /admin/outreach-usa la lee y marca items como enviados.
    match /outreach_queue/{docId} {
      allow read, write: if isAdmin() || isSubadmin();
    }

    // ── outreach_metrics (contadores por preset/mes) ────────────────────────
    // Escriben cron y webhook vía Admin SDK (bypassa rules). Solo lectura.
    match /outreach_metrics/{docId} {
      allow read: if isAdmin() || isSubadmin();
      allow write: if false;
    }

    // ── cancel_surveys (respuestas de encuesta de cancelación) ──────────────
    // Escribe /api/cancel-survey vía Admin SDK. Solo lectura admin.
    match /cancel_surveys/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── usuarios (perfiles) ─────────────────────────────────────────────────
    // Leer: el propio usuario o admin
    // Escribir: admin tiene acceso total; owner solo puede actualizar campos de integración
    match /usuarios/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAdmin() || (isOwner(userId) && request.resource.data.role == "cliente");
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(["role", "email", "displayName"])
        )
        // Allow owner to set sitioId ONLY if they don't have one yet (first purchase)
        || (
          isOwner(userId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["sitioId"])
          && (!("sitioId" in resource.data) || resource.data.sitioId == "" || resource.data.sitioId == null)
        );
    }

    // ── sitios (páginas públicas de clientes) ───────────────────────────────
    // Leer: público (las webs deben ser visibles para todos)
    // SECURITY NOTE: stripeCustomerId/stripeSubscriptionId are stored here.
    // Firestore rules don't support field-level read restrictions.
    // These fields are only written/read server-side via Admin SDK.
    // Public reads expose them — acceptable risk since Stripe IDs alone
    // cannot authorize actions (require Stripe secret key).
    // Crear: admin o usuario autenticado (auto-create al comprar plan)
    // Actualizar: admin full access; owner safe fields; webhook payment fields
    // Eliminar: solo admin
    match /sitios/{sitioId} {
      allow read: if true;
      allow create: if isAdmin()
        || (request.auth != null && request.resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
      allow update: if isAdmin()
        || (
          request.auth != null
          && resource.data.ownerId == request.auth.uid
          && (!request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(["ownerId", "statusPago", "plan", "stripeCustomerId", "stripeSubscriptionId", "fechaVencimiento", "ultimoPagoAt"]))
        )
        // Webhook + bio tracking: use Admin SDK server-side (bypasses rules).
        // No unauthenticated writes allowed.
        ;
    }

    // ── agencias (agency accounts) ──────────────────────────────────────────
    match /agencias/{agenciaId} {
      allow read: if isAdmin()
        || (request.auth != null && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    // ── configuracion (admin settings) ──────────────────────────────────────
    match /configuracion/{docId} {
      allow read, write: if isAdmin();
    }

    // ── savings_logs (AI optimization audit trail — per sitio) ─────────────
    // Subcollection: sitios/{sitioId}/savings_logs/{logId}
    // Read: owner or admin. Write: Admin SDK only (bypasses rules).
    match /sitios/{sitioId}/savings_logs/{logId} {
      allow read: if isAdmin()
        || (request.auth != null && get(/databases/$(database)/documents/sitios/$(sitioId)).data.ownerId == request.auth.uid);
      allow write: if isAdmin(); // AI actions write via Admin SDK server-side
    }

    // ── webhook_events (audit trail — webhook writes, admin reads) ─────────
    match /webhook_events/{eventId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin(); // Webhooks use Admin SDK (bypasses rules)
    }

    // ── Cualquier otra colección: denegado por defecto ──────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
