# ─── Firebase (Client) ───────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Firebase Admin (Server) ────────────────────────────────────────
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Stripe ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=

# ─── OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Anthropic (Claude AI for ad generation) ─────────────────────────
ANTHROPIC_API_KEY=

# ─── Groq (Fallback AI cuando Claude se queda sin créditos) ──────────
GROQ_API_KEY=

# ─── Google Gemini (Image generation) ────────────────────────────────
GEMINI_API_KEY=

# ─── Resend (Email) ──────────────────────────────────────────────────
RESEND_API_KEY=
# Admin inbox for general leads (fallback if B2B_ADMIN_EMAIL is unset)
ADMIN_EMAIL=
# Optional: separate inbox for B2B / agency leads (/api/contact-b2b)
B2B_ADMIN_EMAIL=
# Sender identity (must be verified in Resend)
FROM_EMAIL=
# WhatsApp number used in email CTAs (digits only, with country code)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ─── reCAPTCHA ───────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── Facebook / Meta Ads ─────────────────────────────────────────────
# App ID/Secret de tu Meta App (developers.facebook.com → Mis Apps).
# Para producción, la app necesita App Review aprobando ads_management/ads_read.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Mismo App ID, expuesto al cliente para construir la URL de OAuth.
NEXT_PUBLIC_FACEBOOK_APP_ID=
# El redirect_uri se deriva automáticamente del origin desde el que cargas la app
# (window.location.origin), así que registra en la Meta App TODOS los orígenes que uses:
#   - Producción:  https://<tu-dominio>/api/auth/meta/callback
#   - Local (dev): http://localhost:3000/api/auth/meta/callback

# ─── TikTok Ads ──────────────────────────────────────────────────────
# Crea la app en business-api.tiktok.com/portal/apps. El redirect_uri de TikTok
# está fijo en la UI (no usa el origin de la app), por lo que funciona en localhost.
# Conexión: autorizar en TikTok → copiar el auth_code de la URL → pegarlo en la UI
# (se intercambia en /api/tiktok-ads/oauth). Alternativa: pegar Access Token manual.
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
NEXT_PUBLIC_TIKTOK_APP_ID=

# ─── Google Ads ───────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# El redirect_uri se deriva del origin desde el que cargas la app, así que registra
# todos los que uses en Google Cloud → OAuth 2.0 Client → Authorized redirect URIs:
#   - Producción:  https://<tu-dominio>/api/auth/google-ads/callback
#   - Local (dev): http://localhost:3000/api/auth/google-ads/callback
NEXT_PUBLIC_GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
# Google Ads → Tools & Settings → API Center → Developer token
GOOGLE_ADS_DEVELOPER_TOKEN=
# Manager Account ID (MCC) sin guiones, ej: 1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ─── Token Encryption (AES-256-GCM) ─────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# ─── Site URL (MUST include https://, no trailing slash) ─────────────
# Dominio canónico. Lo usan los emails, Stripe checkout y los <link rel="canonical">.
# NOTA: el redirect_uri de OAuth (Google/Meta) YA NO depende de esta variable —
# se deriva del origin real del request. En local puedes dejar este valor como prod.
NEXT_PUBLIC_SITE_URL=https://indexaia.com

# ─── Cron & Webhooks ────────────────────────────────────────────────
CRON_SECRET=
INGEST_WEBHOOK_SECRET=

# ─── Historias Infinitas (scraper_funerarias.py + /admin/prospectos Funerarias tab) ─
# Base URL de HI. Usa localhost para dev, el dominio real para producción.
HI_API_BASE_URL=https://historias-infinitas.com
# Misma key que INDEXA_API_KEY del lado de HI. Genera con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HI_INDEXA_API_KEY=

# ─── Scraper Service ────────────────────────────────────────────────
SCRAPER_API_URL=
SCRAPER_API_EMAIL=
SCRAPER_API_PASSWORD=

# ─── WhatsApp Cloud API (Meta Graph API) ────────────────────────────
# Obtener en: https://business.facebook.com/wa/manage/phone-numbers/
WHATSAPP_PHONE_NUMBER_ID=
# System User token (long-lived) desde Business Settings → System Users
WHATSAPP_ACCESS_TOKEN=
# Versión del Graph API (opcional, default v21.0)
WHATSAPP_GRAPH_VERSION=v21.0
# Token que tú eliges para verificar el webhook (cualquier string aleatorio)
WHATSAPP_VERIFY_TOKEN=
# App Secret (Meta App → Settings → Basic). Para validar firma X-Hub-Signature-256.
WHATSAPP_APP_SECRET=
# Nombre exacto de la plantilla aprobada en WhatsApp Manager
WHATSAPP_TEMPLATE_NAME=promo_clientes_aviso
WHATSAPP_TEMPLATE_LANG=es_MX

# Plantillas dedicadas para outbound USA-Hispano. Meta exige template aprobada
# por idioma; recomendado registrar las plantillas USA en español neutro ("es")
# para máxima cobertura. Si no se setean, fallback a las plantillas México.
WHATSAPP_TEMPLATE_NAME_USA=usa_cold_opener
WHATSAPP_TEMPLATE_LANG_USA=es

# ─── Maintenance Mode (set to "true" to enable) ─────────────────────
NEXT_PUBLIC_MAINTENANCE_MODE=false
