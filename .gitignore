# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Firebase service account key (NEVER commit)
serviceAccountKey.json
**/serviceAccountKey.json
*firebase-adminsdk*.json

# Claude worktrees
.claude/

# Python scraper outputs
.venv/
scripts/__pycache__/
scripts/*.json
!scripts/requirements.txt
__pycache__/
*.pyc
prospectos_output.json
logs_scraper.txt
logs_funerarias.txt
debug_*.png
tmp-*.cjs

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Assets generados por IA (Estudio Creativo) — nunca commitear
/creatives/
